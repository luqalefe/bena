###
### Env carregado quando APP_ENV=testing.
### Definimos AQUI tudo que os testes precisam — `.env` NÃO é fallback
### quando o framework encontra um arquivo específico do ambiente.
###

APP_NAME="Ponto Estagiarios (testing)"
APP_ENV=testing
APP_KEY=base64:6kE6eS7H5vB1n0a0x3o5b8L2X4zZsTQ4eCk2BZ4nKRk=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

AUTHELIA_DEV_BYPASS=false
TRUSTED_PROXIES=127.0.0.1
