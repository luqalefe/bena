###
### App
###
APP_NAME="Ponto Estagiarios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Rio_Branco
APP_URL=http://localhost:8082
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

###
### Logging
###
LOG_CHANNEL=stack
LOG_LEVEL=debug

###
### Database — Oracle XE 21 (dev container).
### In CI/tests, phpunit.xml overrides to sqlite in-memory.
###
DB_CONNECTION=oracle
DB_HOST=oracle
DB_PORT=1521
DB_SERVICE_NAME=XEPDB1
DB_DATABASE=XEPDB1
DB_USERNAME=ponto
DB_PASSWORD=secret

###
### Cache / Sessions / Queue — driver `database` (sem Redis).
###
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

###
### Authelia integration.
### Em DEV, a app simula os headers (Remote-User/Groups/Name/Email) via
### bypass — não rodamos Authelia local. Em produção, Authelia atrás do
### reverse proxy (configurado via LDAP) injeta os headers reais; o bypass
### é ignorado quando APP_ENV=production.
###
AUTHELIA_DEV_BYPASS=true
AUTHELIA_DEV_USER=lucas.dev
AUTHELIA_DEV_GROUPS=estagiarios
AUTHELIA_DEV_NAME="Lucas Dev"
AUTHELIA_DEV_EMAIL=lucas.dev@example.local
