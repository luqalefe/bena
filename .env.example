###
### App
###
APP_NAME="Ponto Estagiarios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://ponto.localhost
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

###
### Logging
###
LOG_CHANNEL=stack
LOG_LEVEL=debug

###
### Database — Oracle (dev container) by default.
### In CI/tests, phpunit.xml overrides to sqlite in-memory.
###
DB_CONNECTION=oracle
DB_HOST=oracle
DB_PORT=1521
DB_SERVICE_NAME=FREEPDB1
DB_DATABASE=FREEPDB1
DB_USERNAME=ponto
DB_PASSWORD=ponto_dev_only

###
### Oracle bootstrap (used by oracle container only)
###
ORACLE_PASSWORD=oracle_root_dev
ORACLE_APP_USER=ponto
ORACLE_APP_USER_PASSWORD=ponto_dev_only

###
### Cache / Sessions / Queue
###
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=30
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

###
### Authelia integration.
### Em DEV, a app simula os headers (Remote-User/Groups/Name/Email) via
### bypass — não rodamos Authelia local. Em produção, Authelia atrás do
### Traefik (configurado via LDAP) injeta os headers reais; o bypass
### é ignorado quando APP_ENV=production.
###
### Para trocar o usuário simulado em runtime sem reiniciar, abra
###   https://ponto.localhost/_dev/sessao
### e selecione outro usuário/grupo.
###
AUTHELIA_DEV_BYPASS=true
AUTHELIA_DEV_USER=lucas.dev
AUTHELIA_DEV_GROUPS=estagiarios
AUTHELIA_DEV_NAME="Lucas Dev"
AUTHELIA_DEV_EMAIL=lucas.dev@example.local

###
### Trusted proxies — Traefik network only. NEVER use '*' in production.
### Docker default bridge networks live in 172.16.0.0/12.
###
TRUSTED_PROXIES=172.16.0.0/12

###
### Reverse proxy host (usado por traefik labels)
###
APP_HOST=ponto.localhost
